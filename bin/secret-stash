#!/usr/bin/env php
<?php

/**
 * SecretStash CLI - Standalone Entry Point
 *
 * This file serves as the vendor/bin entry point for non-Laravel projects.
 * Laravel users can continue using Artisan commands as before.
 */

// Find the Composer autoloader
$autoloadPaths = [
    __DIR__.'/../vendor/autoload.php',       // When running from the package repo directly
    __DIR__.'/../../../autoload.php',         // When installed as a Composer dependency
];

$autoloaderFound = false;
foreach ($autoloadPaths as $autoloadPath) {
    if (file_exists($autoloadPath)) {
        require $autoloadPath;
        $autoloaderFound = true;
        break;
    }
}

if (! $autoloaderFound) {
    fwrite(STDERR, "Could not find Composer autoloader. Please run 'composer install' first.\n");
    exit(1);
}

use Dniccum\SecretStash\Commands\SecretStashEnvelopeCommand;
use Dniccum\SecretStash\Commands\SecretStashEnvironmentsCommand;
use Dniccum\SecretStash\Commands\SecretStashInstallCommand;
use Dniccum\SecretStash\Commands\SecretStashKeysCommand;
use Dniccum\SecretStash\Commands\SecretStashVariablesCommand;
use Symfony\Component\Console\Application;

$application = new Application('SecretStash CLI', '1.0.1');

$application->add(new SecretStashInstallCommand);
$application->add(new SecretStashKeysCommand);
$application->add(new SecretStashVariablesCommand);
$application->add(new SecretStashEnvironmentsCommand);
$application->add(new SecretStashEnvelopeCommand);

$application->run();
